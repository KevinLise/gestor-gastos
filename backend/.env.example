# ============================================
# backend/.env.example
# Copia este archivo como .env y rellena los valores
# ============================================

# Puerto del servidor
PORT=5000

# MongoDB Atlas
# Obtén tu URI en: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/gestor-gastos?retryWrites=true&w=majority

# ExchangeRate API (gratis en https://www.exchangerate-api.com)
EXCHANGERATE_API_KEY=tu_api_key_aqui

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000
